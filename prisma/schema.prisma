// TL Portal — Track Lucia admin
// https://www.prisma.io/docs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---

enum DeviceStatus {
  in_stock
  assigned
  suspended
  returned
  decommissioned
  lost
}

enum DeviceCondition {
  new
  refurbished
  faulty
}

enum ServiceAssignmentStatus {
  active
  due_soon
  overdue
  suspended
  cancelled
}

enum RegistrationRequestStatus {
  pending
  approved
  rejected
}

/// Commercial / lifecycle classification (default: customer-facing production units).
enum DeviceUsagePurpose {
  customer
  internal_demo
  field_test
  personal
}

/// What the tracker is installed on (fleet / ops labeling).
enum DeviceObjectType {
  car
  bike
  ambulance
  fire_truck
  atv
  boat
  container
  bus
  garbage_truck
  jet_ski
  speed_boat
}

// --- App config (singleton row id = "default") ---

model AppSettings {
  id      String   @id
  logoUrl String?
  /// Outgoing mail (SMTP). When `smtpHost` is null, other SMTP fields are ignored.
  smtpHost      String?
  smtpPort      Int @default(587)
  /// When true, Nodemailer uses implicit TLS (typical for port 465).
  smtpSecure    Boolean @default(false)
  smtpUser      String?
  smtpPassword  String?
  smtpFromEmail String?
  smtpFromName  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Auth (admin) ---

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  reviewedRegistrationRequests RegistrationRequest[] @relation("RegistrationReviewedBy")
}

// --- Core domain ---

model Customer {
  id                  String    @id @default(uuid())
  firstName           String?
  lastName            String?
  company             String?
  email               String?
  phone               String?
  /// Street / multi-line address (Invoiless “Address”); city/state/postal/country are composed into billTo.address on sync.
  address             String?
  city                String?
  state               String?
  postalCode          String?
  country             String?
  /// Maps to Invoiless billTo.legal (e.g. company / tax registration).
  legalInfo           String?
  /// Comma-separated Cc emails for invoice sends (Invoiless max 3).
  invoiceCc           String?
  /// Comma-separated Bcc emails (Invoiless max 3).
  invoiceBcc          String?
  invoilessCustomerId String?   @unique
  /// Traqcare GPS portal login (optional).
  traqcareUsername    String?
  /// Stored in DB as plain text — restrict DB access; prefer env/secret store for production.
  traqcarePassword    String?
  /// Traqcare / white-label portal base URL if not the default (e.g. https://…).
  traqcarePortalUrl   String?
  notes               String?
  tags                String[]  @default([])
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  serviceAssignments ServiceAssignment[]

  registrationEmailMatches RegistrationRequest[] @relation("RegistrationEmailMatchCustomer")
  createdFromRegistration    RegistrationRequest?  @relation("RegistrationCreatedCustomer")

  @@index([email])
}

/// Public registration form — subscription choice labels (staff CRUD).
model SubscriptionOption {
  id        String   @id @default(uuid())
  label     String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  registrationRequests RegistrationRequest[]
}

/// Client-submitted registration; staff approves → Customer created (Invoiless separate).
model RegistrationRequest {
  id     String                    @id @default(uuid())
  status RegistrationRequestStatus @default(pending)

  firstName String
  lastName  String
  /// WhatsApp / primary phone from the registration form.
  phone String
  email String

  vehicleDetails       String  @db.Text
  subscriptionOptionId String?
  subscriptionOption   SubscriptionOption? @relation(fields: [subscriptionOptionId], references: [id], onDelete: SetNull)

  termInstallAfterPayment Boolean
  termHardwarePerVehicle  Boolean
  termTravelFee           Boolean

  /// Existing customer with the same email (reviewer duplicate flag).
  matchesCustomerId String?
  matchesCustomer   Customer? @relation("RegistrationEmailMatchCustomer", fields: [matchesCustomerId], references: [id], onDelete: SetNull)
  /// Count of other pending rows with the same email when this row was submitted.
  otherPendingSameEmail Int @default(0)

  submittedAt DateTime  @default(now())
  reviewedAt  DateTime?
  reviewedById String?
  reviewedBy   User?   @relation("RegistrationReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  rejectionReason String? @db.Text

  createdCustomerId String?  @unique
  createdCustomer   Customer? @relation("RegistrationCreatedCustomer", fields: [createdCustomerId], references: [id], onDelete: SetNull)

  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([submittedAt])
}

model DeviceModel {
  id                 String   @id @default(uuid())
  name               String
  manufacturer       String?
  category           String?
  description        String?
  retailPrice        Decimal  @db.Decimal(12, 2)
  costPrice          Decimal? @db.Decimal(12, 2)
  invoilessProductId String?  @unique
  isActive           Boolean  @default(true)
  imageUrl           String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  devices Device[]
}

model Device {
  id                String          @id @default(uuid())
  imei              String          @unique
  serialNumber      String?
  label             String?
  status            DeviceStatus    @default(in_stock)
  condition         DeviceCondition @default(new)
  purchasedAt       DateTime?
  warrantyExpiresAt DateTime?
  firmwareVersion   String?
  notes             String?
  /// Billable / customer-facing vs internal, demo, or personal test units.
  usagePurpose DeviceUsagePurpose @default(customer)
  /// Vehicle / asset class for UI and reporting (optional).
  objectType   DeviceObjectType?
  /// Free-form labels (e.g. demo-booth, test-vehicle-a); use for search and reporting.
  tags         String[]           @default([])
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  deviceModelId String
  deviceModel   DeviceModel @relation(fields: [deviceModelId], references: [id], onDelete: Restrict)

  simCardId String?  @unique
  simCard   SimCard? @relation(fields: [simCardId], references: [id], onDelete: SetNull)

  serviceAssignments ServiceAssignment[]

  @@index([deviceModelId])
  @@index([status])
  @@index([usagePurpose])
  @@index([objectType])
}

model SimCard {
  id             String    @id @default(uuid())
  iccid          String    @unique
  msisdn         String?
  imsi           String?
  label          String?
  status         String    @default("Active")
  totalDataMB    Float?
  usedDataMB     Float?
  dataExpiryDate DateTime?
  lastSyncedAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  device Device?

  serviceAssignments ServiceAssignment[]

  @@index([iccid])
  @@index([status])
  @@index([usedDataMB])
}

model ServiceAssignment {
  id                   String                   @id @default(uuid())
  startDate            DateTime?
  endDate              DateTime?
  status               ServiceAssignmentStatus  @default(active)
  invoilessRecurringId String?
  intervalMonths       Int?
  lastInvoiceId        String?
  lastPaymentStatus    String?
  nextDueDate          DateTime?
  notes                String?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  deviceId String
  device   Device @relation(fields: [deviceId], references: [id], onDelete: Restrict)

  simCardId String?
  simCard   SimCard? @relation(fields: [simCardId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([deviceId])
  @@index([status])
  @@index([nextDueDate])
}
