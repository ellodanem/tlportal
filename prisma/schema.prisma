// TL Portal — Track Lucia admin
// https://www.prisma.io/docs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---

enum DeviceStatus {
  in_stock
  assigned
  suspended
  returned
  decommissioned
  lost
}

enum DeviceCondition {
  new
  refurbished
  faulty
}

enum ServiceAssignmentStatus {
  active
  due_soon
  overdue
  suspended
  cancelled
}

/// Why a service assignment was paused (hardware offline, no vehicle, etc.).
enum ServiceAssignmentPauseReason {
  accident
  no_vehicle
  seasonal
  delinquent
  other
}

enum RegistrationRequestStatus {
  pending
  approved
  rejected
}

/// Commercial / lifecycle classification (default: customer-facing production units).
enum DeviceUsagePurpose {
  customer
  internal_demo
  field_test
  personal
}

/// What the tracker is installed on (fleet / ops labeling).
enum DeviceObjectType {
  car
  bike
  ambulance
  fire_truck
  atv
  boat
  container
  bus
  garbage_truck
  jet_ski
  speed_boat
}

enum ProposalStatus {
  draft
  sent
}

enum ProposalLineCategory {
  hardware
  subscription
  installation
  service
  other
}

enum ProposalVisualKind {
  media
  timeline
}

enum ProposalVisualLayout {
  full_width
  half_width
}

/// Sidebar logo height preset (admin branding).
enum BrandingLogoSize {
  s
  m
  l
  xl
}

/// How the customer is billed (TL ops view; provider details on BillingAccount).
enum CustomerBillingMode {
  manual_legacy
  stripe_subscription
}

enum BillingProvider {
  invoiless
  stripe
}

enum BillingInvoiceKind {
  subscription
  one_time
}

// --- Native billing (Phase 0): TL-owned quotes / invoices / payments ---

/// Lifecycle of a native TL quote (estimate). `converted` once an Invoice is generated from it.
enum QuoteStatus {
  draft
  sent
  accepted
  declined
  expired
  converted
}

/// Lifecycle of a native TL invoice (the AR record). Distinct from the Stripe `BillingInvoice` mirror.
enum InvoiceStatus {
  draft
  open
  partially_paid
  paid
  overdue
  void
  written_off
}

/// Origin of a native invoice. `subscription_mirror` reserved for unifying Stripe invoices (Phase 4).
enum InvoiceKind {
  one_off
  recurring
  subscription_mirror
  /// Historical row imported from Invoiless at cutover (Phase 7).
  invoiless_import
}

/// How a recorded payment was received against a native invoice.
enum PaymentMethod {
  stripe
  cash
  bank_transfer
  cheque
  card_manual
  other
}

/// Lifecycle of a native recurring invoice schedule (cash/cheque/bank payers).
enum RecurringScheduleStatus {
  active
  paused
  ended
}

/// How an expense was paid (Phase 5 — simple expense register).
enum ExpensePaymentMethod {
  cash
  bank_transfer
  card
  cheque
  other
}

/// TL-owned subscription lifecycle (Stripe mirrors payment; this is ops source of truth).
enum CustomerSubscriptionStatus {
  pending_payment
  active
  past_due
  unpaid
  canceled
  trialing
  paused
}

/// Broadcast message templates (email now; WhatsApp body reserved for phase 2).
enum BroadcastTemplateCategory {
  outage
  maintenance
  general
  billing
}

enum BroadcastCampaignStatus {
  queued
  sending
  completed
  completed_with_errors
  failed
  cancelled
}

enum BroadcastDeliveryStatus {
  pending
  sent
  failed
  skipped
}

/// GPS / telematics platform linked to a device.
enum GpsProvider {
  traqcare
}

enum DeviceLinkRole {
  primary
  secondary
  migrating
}

/// Atomic counter for customer-facing `TL-INV-{n}` numbers (singleton id = "default").
/// Shared by the Stripe `BillingInvoice` mirror AND native `Invoice` so numbers never collide.
model InvoiceSequence {
  id        String   @id
  nextValue Int
  updatedAt DateTime @updatedAt
}

/// Atomic counter for customer-facing `TL-Q-{n}` quote numbers (singleton id = "default").
model QuoteSequence {
  id        String   @id
  nextValue Int
  updatedAt DateTime @updatedAt
}

// --- App config (singleton row id = "default") ---

model AppSettings {
  id                          String           @id
  logoUrl                     String?
  logoSize                    BrandingLogoSize @default(m)
  /// Outgoing mail (SMTP). When `smtpHost` is null, other SMTP fields are ignored.
  smtpHost                    String?
  smtpPort                    Int              @default(587)
  /// When true, Nodemailer uses implicit TLS (typical for port 465).
  smtpSecure                  Boolean          @default(false)
  smtpUser                    String?
  smtpPassword                String?
  smtpFromEmail               String?
  smtpFromName                String?
  /// Comma- or newline-separated E.164-ish phones for billing ops SMS (missing pay link, etc.).
  billingAlertPhones          String?          @db.Text
  /// When true, email TL paid receipt PDFs on Stripe `invoice.paid` (requires SMTP).
  autoEmailPaidStripeReceipts Boolean          @default(true)
  /// IANA timezone for portal calendar dates (billing reminders, due dates). Default St. Lucia.
  businessTimezone            String           @default("America/St_Lucia")
  /// Human-readable business location label (e.g. St. Lucia).
  businessLocation            String           @default("St. Lucia")
  createdAt                   DateTime         @default(now())
  updatedAt                   DateTime         @updatedAt
}

// --- Auth (admin) ---

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  reviewedRegistrationRequests RegistrationRequest[] @relation("RegistrationReviewedBy")
  proposalsCreated             Proposal[]

  // Native billing (Phase 0) — staff authorship / payment recording.
  quotesCreated                 Quote[]
  invoicesCreated               Invoice[]
  paymentsRecorded              Payment[]
  recurringSchedulesCreated     RecurringInvoiceSchedule[]
  expensesRecorded              Expense[]
}

// --- Core domain ---

model Customer {
  id                   String              @id @default(uuid())
  firstName            String?
  lastName             String?
  company              String?
  email                String?
  phone                String?
  /// Street / multi-line address (Invoiless “Address”); city/state/postal/country are composed into billTo.address on sync.
  address              String?
  city                 String?
  state                String?
  postalCode           String?
  country              String?
  /// Maps to Invoiless billTo.legal (e.g. company / tax registration).
  legalInfo            String?
  /// Comma-separated Cc emails for invoice sends (Invoiless max 3).
  invoiceCc            String?
  /// Comma-separated Bcc emails (Invoiless max 3).
  invoiceBcc           String?
  /// Preferred billing path for new workflows (legacy rows default manual_legacy).
  billingMode          CustomerBillingMode @default(manual_legacy)
  /// Custom Stripe subscription monthly rate (XCD). Null = default catalog / env Price ids.
  stripeMonthlyRateXcd Decimal?            @db.Decimal(10, 2)
  /// @deprecated Prefer BillingAccount — kept for backward compatibility during Phase 1.
  invoilessCustomerId  String?             @unique
  /// @deprecated Prefer ProviderDeviceLink on Device — kept during Phase 1 migration.
  traqcareUsername     String?
  /// Stored in DB as plain text — restrict DB access; prefer env/secret store for production.
  traqcarePassword     String?
  /// Traqcare / white-label portal base URL if not the default (e.g. https://…).
  traqcarePortalUrl    String?
  /// Traqcare live API `clientid` — one fleet id per customer (copy from Traqcare platform).
  traqcareClientId     String?
  notes                String?
  tags                 String[]            @default([])
  /// Set when staff archives a churned / inactive account — hidden from active lists and billing reminders.
  archivedAt           DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  serviceAssignments         ServiceAssignment[]
  billingAccounts            BillingAccount[]
  billingInvoices            BillingInvoice[]
  billingWhatsAppReminders   BillingWhatsAppReminder[]
  billingPayLinkAdminAlerts  BillingPayLinkAdminAlert[]
  customerWhatsAppDeliveries CustomerWhatsAppDelivery[]
  customerSubscriptions      CustomerSubscription[]
  operationalEvents          OperationalEvent[]
  broadcastDeliveries        BroadcastDelivery[]

  registrationEmailMatches RegistrationRequest[] @relation("RegistrationEmailMatchCustomer")
  createdFromRegistration  RegistrationRequest?  @relation("RegistrationCreatedCustomer")
  proposals                Proposal[]

  // Native billing (Phase 0) — TL-owned quotes, invoices, payments.
  quotes                  Quote[]
  invoices                Invoice[]
  payments                Payment[]
  recurringInvoiceSchedules RecurringInvoiceSchedule[]
  expenses                Expense[]
  @@index([archivedAt])
}

/// Public registration form — four fixed terms (1 / 3 / 6 / 12 month); staff edit price only.
model SubscriptionOption {
  id             String   @id @default(uuid())
  /// Billing term length in months; exactly one row per value in { 1, 3, 6, 12 }.
  durationMonths Int      @unique
  priceXcd       Decimal  @db.Decimal(10, 2)
  /// Stripe Price id (`price_…`) for Checkout; overrides env `STRIPE_PRICE_ID_*` when set.
  stripePriceId  String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  registrationRequests RegistrationRequest[]
}

/// Stripe catalog: per-vehicle Price id for monthly rate tier × billing term (Checkout quantity = vehicles).
model SubscriptionCatalogPrice {
  id             String   @id @default(uuid())
  /// Per-vehicle monthly rate tier (e.g. 30, 25, 20 XCD).
  monthlyRateXcd Decimal  @db.Decimal(10, 2)
  durationMonths Int
  /// Stripe Price (`price_…`) per vehicle for this billing interval.
  stripePriceId  String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([monthlyRateXcd, durationMonths])
  @@index([durationMonths])
}

/// Client-submitted registration; staff approves → Customer created (Invoiless separate).
model RegistrationRequest {
  id     String                    @id @default(uuid())
  status RegistrationRequestStatus @default(pending)

  firstName String
  lastName  String
  /// WhatsApp / primary phone from the registration form.
  phone     String
  email     String

  vehicleDetails       String              @db.Text
  /// Optional extra portal users from the registration form (free text, one per line).
  additionalUsers      String?             @db.Text
  subscriptionOptionId String?
  subscriptionOption   SubscriptionOption? @relation(fields: [subscriptionOptionId], references: [id], onDelete: SetNull)

  termInstallAfterPayment Boolean
  termHardwarePerVehicle  Boolean
  termTravelFee           Boolean

  /// Existing customer with the same email (reviewer duplicate flag).
  matchesCustomerId     String?
  matchesCustomer       Customer? @relation("RegistrationEmailMatchCustomer", fields: [matchesCustomerId], references: [id], onDelete: SetNull)
  /// Count of other pending rows with the same email when this row was submitted.
  otherPendingSameEmail Int       @default(0)

  submittedAt     DateTime  @default(now())
  reviewedAt      DateTime?
  reviewedById    String?
  reviewedBy      User?     @relation("RegistrationReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  rejectionReason String?   @db.Text

  createdCustomerId String?   @unique
  createdCustomer   Customer? @relation("RegistrationCreatedCustomer", fields: [createdCustomerId], references: [id], onDelete: SetNull)

  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([submittedAt])
}

model DeviceModel {
  id                 String   @id @default(uuid())
  name               String
  manufacturer       String?
  category           String?
  description        String?
  retailPrice        Decimal  @db.Decimal(12, 2)
  costPrice          Decimal? @db.Decimal(12, 2)
  invoilessProductId String?  @unique
  isActive           Boolean  @default(true)
  imageUrl           String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  devices Device[]
}

model Device {
  id                String             @id @default(uuid())
  imei              String             @unique
  serialNumber      String?
  label             String?
  status            DeviceStatus       @default(in_stock)
  condition         DeviceCondition    @default(new)
  purchasedAt       DateTime?
  warrantyExpiresAt DateTime?
  firmwareVersion   String?
  notes             String?
  /// Billable / customer-facing vs internal, demo, or personal test units.
  usagePurpose      DeviceUsagePurpose @default(customer)
  /// Vehicle / asset class for UI and reporting (optional).
  objectType        DeviceObjectType?
  /// Free-form labels (e.g. demo-booth, test-vehicle-a); use for search and reporting.
  tags              String[]           @default([])
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  deviceModelId String
  deviceModel   DeviceModel @relation(fields: [deviceModelId], references: [id], onDelete: Restrict)

  simCardId String?  @unique
  simCard   SimCard? @relation(fields: [simCardId], references: [id], onDelete: SetNull)

  serviceAssignments  ServiceAssignment[]
  providerDeviceLinks ProviderDeviceLink[]
  operationalEvents   OperationalEvent[]
  expenses            Expense[]

  @@index([deviceModelId])
  @@index([status])
  @@index([usagePurpose])
  @@index([objectType])
}

model SimCard {
  id             String    @id @default(uuid())
  iccid          String    @unique
  msisdn         String?
  imsi           String?
  label          String?
  status         String    @default("Active")
  totalDataMB    Float?
  usedDataMB     Float?
  dataExpiryDate DateTime?
  lastSyncedAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  device Device?

  serviceAssignments ServiceAssignment[]

  @@index([iccid])
  @@index([status])
  @@index([usedDataMB])
}

model ServiceAssignment {
  id                   String                  @id @default(uuid())
  startDate            DateTime?
  endDate              DateTime?
  status               ServiceAssignmentStatus @default(active)
  invoilessRecurringId String?
  intervalMonths       Int?
  lastInvoiceId        String?
  lastPaymentStatus    String?
  nextDueDate          DateTime?
  notes                String?
  pausedAt             DateTime?
  pauseReason          ServiceAssignmentPauseReason?
  pauseNote            String?                     @db.Text
  /// Snapshot of next due at pause (time-freeze on resume for manual billing).
  frozenNextDueDate    DateTime?
  resumedAt            DateTime?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  deviceId String
  device   Device @relation(fields: [deviceId], references: [id], onDelete: Restrict)

  simCardId String?
  simCard   SimCard? @relation(fields: [simCardId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([deviceId])
  @@index([status])
  @@index([nextDueDate])
}

/// Sales proposal (PDF to client). Estimate/invoice flow is separate (e.g. Invoiless).
model Proposal {
  id     String         @id @default(uuid())
  status ProposalStatus @default(draft)

  title String

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  /// Primary display name on cover (company or contact).
  clientLabel       String?
  clientCompany     String?
  clientContactName String?
  clientEmail       String?
  clientPhone       String?
  clientAddress     String? @db.Text

  executiveSummary String? @db.Text
  /// Plain text: one bullet per line for the “included capabilities” section.
  includedFeatures String? @db.Text
  assumptionsText  String? @db.Text
  nextStepsText    String? @db.Text
  termsText        String? @db.Text
  pricingFootnote  String? @db.Text

  currencyCode String @default("XCD")
  validityDays Int    @default(14)

  salesContactName  String?
  salesContactTitle String?
  salesContactEmail String?
  salesContactPhone String?

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  lineItems ProposalLineItem[]
  visuals   ProposalVisualBlock[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([updatedAt])
}

model ProposalLineItem {
  id String @id @default(uuid())

  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  sortOrder Int                  @default(0)
  category  ProposalLineCategory @default(other)

  description String
  quantity    Decimal @default(1) @db.Decimal(12, 4)
  unitLabel   String?
  unitPrice   Decimal @db.Decimal(12, 2)

  @@index([proposalId])
}

model ProposalVisualBlock {
  id String @id @default(uuid())

  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  sortOrder       Int                  @default(0)
  title           String
  caption         String?              @db.Text
  imageUrl        String?
  placeholderHint String?
  /// Accessibility / PDF note when an image is present.
  imageAlt        String?
  kind            ProposalVisualKind   @default(media)
  layout          ProposalVisualLayout @default(full_width)
  /// When `kind` is `timeline`, JSON array of { "title": string, "detail"?: string }.
  timelineSteps   Json?

  @@index([proposalId])
}

// --- Vendor abstraction (Phase 1) ---

/// External billing identity per customer (Invoiless, Stripe, …).
model BillingAccount {
  id                 String              @id @default(uuid())
  customerId         String
  customer           Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  provider           BillingProvider
  externalCustomerId String
  mode               CustomerBillingMode @default(manual_legacy)
  /// Provider-specific status mirror (e.g. Stripe subscription status).
  status             String?
  metadata           Json?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([customerId, provider])
  @@unique([provider, externalCustomerId])
  @@index([customerId])
}

/// Mirrored invoice from a billing provider (Stripe subscription/one-time, future Invoiless).
model BillingInvoice {
  id                       String             @id @default(uuid())
  customerId               String
  customer                 Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  provider                 BillingProvider
  externalInvoiceId        String
  kind                     BillingInvoiceKind @default(subscription)
  status                   String
  amountXcd                Decimal            @db.Decimal(12, 2)
  currency                 String             @default("xcd")
  /// Customer-facing number on PDF and Billing UI (e.g. TL-INV-100837).
  displayNumber            String?            @unique
  /// Provider invoice number (Stripe `invoice.number`).
  providerInvoiceNumber    String?
  periodStart              DateTime?
  periodEnd                DateTime?
  hostedInvoiceUrl         String?
  invoicePdfUrl            String?
  stripeSubscriptionId     String?
  paidAt                   DateTime?
  /// Invoiless invoice id created when mirroring Stripe `invoice.paid` (accounting copy).
  invoilessMirrorInvoiceId String?
  /// Vercel Blob path prefix `private:` + url, or public blob url for TL paid PDF.
  pdfStoragePath           String?
  pdfGeneratedAt           DateTime?
  /// When the TL paid receipt PDF was emailed to the customer (auto or manual).
  receiptEmailedAt         DateTime?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  /// Unified AR row in native `Invoice` (Phase 4).
  nativeMirror Invoice?

  @@unique([provider, externalInvoiceId])
  @@index([customerId, createdAt(sort: Desc)])
  @@index([status])
}

/// Sent billing WhatsApp reminders (Twilio Content); one row per customer × kind × due date.
model BillingWhatsAppReminder {
  id               String   @id @default(uuid())
  customerId       String
  customer         Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  /// due_5d | due_3d | due_0d | overdue_3d | overdue_5d
  reminderKind     String
  nextDueDate      DateTime @db.Date
  twilioMessageSid String?
  payLinkSource    String?
  sentAt           DateTime @default(now())

  @@unique([customerId, reminderKind, nextDueDate])
  @@index([customerId, sentAt(sort: Desc)])
}

/// One-off customer WhatsApp (Stripe checkout link, new Invoiless invoice).
model CustomerWhatsAppDelivery {
  id               String   @id @default(uuid())
  customerId       String
  customer         Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  kind             String
  externalRef      String
  twilioMessageSid String?
  sentAt           DateTime @default(now())

  @@unique([kind, externalRef])
  @@index([customerId, sentAt(sort: Desc)])
}

/// Staff SMS sent when a customer reminder was skipped (no pay link).
model BillingPayLinkAdminAlert {
  id           String   @id @default(uuid())
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  reminderKind String
  nextDueDate  DateTime @db.Date
  notifiedAt   DateTime @default(now())

  @@unique([customerId, reminderKind, nextDueDate])
  @@index([notifiedAt(sort: Desc)])
}

/// Idempotency for Stripe webhooks (`evt_…` primary key).
model StripeWebhookEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now())

  @@index([processedAt])
}

/// Customer-level subscription (TL source of truth; Stripe id when linked).
model CustomerSubscription {
  id                   String                     @id @default(uuid())
  customerId           String
  customer             Customer                   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  status               CustomerSubscriptionStatus @default(pending_payment)
  /// Billing term length in months (1, 3, 6, 12).
  planTermMonths       Int
  /// Monthly rate in XCD used for this subscription (null = catalog default at checkout).
  monthlyRateXcd       Decimal?                   @db.Decimal(10, 2)
  /// Billed vehicle/device quantity when set; otherwise derived from active assignments in UI.
  vehicleCount         Int?
  stripeSubscriptionId String?                    @unique
  stripeCustomerId     String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAt             DateTime?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  @@index([customerId, updatedAt(sort: Desc)])
  @@index([status])
}

/// Maps a TL device to a vendor GPS/telematics identity.
model ProviderDeviceLink {
  id                 String         @id @default(uuid())
  deviceId           String
  device             Device         @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  provider           GpsProvider
  externalDeviceId   String?
  externalAccountRef String?
  portalUrl          String?
  role               DeviceLinkRole @default(primary)
  linkedAt           DateTime       @default(now())
  unlinkedAt         DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@unique([deviceId, provider])
  @@index([deviceId])
  @@index([provider])
}

/// Reusable copy for customer broadcast emails (and future WhatsApp).
model BroadcastTemplate {
  id           String                    @id @default(uuid())
  /// Stable key for seeded system templates (`outage-investigating`, etc.).
  slug         String?                   @unique
  name         String
  category     BroadcastTemplateCategory @default(general)
  subject      String
  bodyText     String                    @db.Text
  /// Phase 2: shorter plain body for WhatsApp when channel is enabled.
  whatsappBody String?                   @db.Text
  isSystem     Boolean                   @default(false)
  isActive     Boolean                   @default(true)
  sortOrder    Int                       @default(0)
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  campaigns    BroadcastCampaign[]

  @@index([category])
  @@index([isActive, sortOrder])
}

/// Mass email send to a filtered customer audience (snapshot subject/body at send time).
model BroadcastCampaign {
  id               String                  @id @default(uuid())
  templateId       String?
  template         BroadcastTemplate?      @relation(fields: [templateId], references: [id], onDelete: SetNull)
  subjectSnapshot  String
  bodyTextSnapshot String                  @db.Text
  /// When false, only customers with an active service assignment; when true, all customers with email.
  includeInactive  Boolean                 @default(false)
  incidentTitle    String?
  incidentStatus   String?
  incidentEta      String?
  status           BroadcastCampaignStatus @default(queued)
  totalRecipients  Int                     @default(0)
  sentCount        Int                     @default(0)
  failedCount      Int                     @default(0)
  skippedCount     Int                     @default(0)
  actorUserId      String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  startedAt        DateTime?
  completedAt      DateTime?

  deliveries BroadcastDelivery[]

  @@index([status, createdAt])
  @@index([createdAt])
}

/// Per-customer email attempt for a broadcast campaign.
model BroadcastDelivery {
  id         String                  @id @default(uuid())
  campaignId String
  campaign   BroadcastCampaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer                @relation(fields: [customerId], references: [id], onDelete: Cascade)
  email      String
  status     BroadcastDeliveryStatus @default(pending)
  error      String?
  sentAt     DateTime?
  createdAt  DateTime                @default(now())

  @@unique([campaignId, customerId])
  @@index([campaignId, status])
  @@index([customerId])
}

/// TL-native audit trail for ops and future automation (not vendor telemetry).
model OperationalEvent {
  id          String    @id @default(uuid())
  occurredAt  DateTime  @default(now())
  category    String
  summary     String
  payload     Json?
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  deviceId    String?
  device      Device?   @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  actorUserId String?

  @@index([customerId, occurredAt])
  @@index([deviceId, occurredAt])
  @@index([category, occurredAt])
}

// --- Native billing (Phase 0) ---
// TL-owned quote → invoice → payment lifecycle. Additive to the existing
// Invoiless (external) and Stripe `BillingInvoice` (mirror) flows; nothing here
// replaces them yet. UI wiring and cutover happen in later phases.

/// TL-native quote / estimate. Persisted (unlike the legacy stateless quick-quote).
model Quote {
  id     String      @id @default(uuid())
  status QuoteStatus @default(draft)

  /// Customer-facing number, `TL-Q-{n}`, allocated from QuoteSequence when sent.
  number String? @unique

  /// Optional linked customer; free-text bill-to is supported for ad-hoc estimates.
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  /// Snapshot of who the quote is addressed to (stable even if the Customer is later edited).
  billToName  String?
  billToLines String[] @default([])

  currency       String   @default("XCD")
  /// Stored money snapshots (computed from line items at save time).
  subtotal       Decimal  @default(0) @db.Decimal(12, 2)
  /// Single document-level tax (e.g. VAT). Per-line tax is out of scope for Phase 0.
  taxLabel       String?
  taxRatePercent Decimal? @db.Decimal(5, 2)
  taxTotal       Decimal  @default(0) @db.Decimal(12, 2)
  total          Decimal  @default(0) @db.Decimal(12, 2)

  issueDate  DateTime  @default(now())
  validUntil DateTime?
  notes      String?   @db.Text

  /// Public accept/decline token for a shareable quote link.
  publicToken String?   @unique
  sentAt      DateTime?
  acceptedAt  DateTime?
  declinedAt  DateTime?

  pdfStoragePath String?
  pdfGeneratedAt DateTime?

  /// Invoice generated from this quote (set when status = converted).
  convertedInvoiceId String?  @unique
  convertedInvoice   Invoice? @relation("QuoteConvertedInvoice", fields: [convertedInvoiceId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  lineItems QuoteLineItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([updatedAt])
}

model QuoteLineItem {
  id String @id @default(uuid())

  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  sortOrder   Int     @default(0)
  description String
  quantity    Decimal @default(1) @db.Decimal(12, 4)
  unitLabel   String?
  unitPrice   Decimal @db.Decimal(12, 2)
  /// quantity × unitPrice, snapshotted at save time.
  lineTotal   Decimal @default(0) @db.Decimal(12, 2)

  @@index([quoteId])
}

/// TL-native invoice — the going-forward AR record (Invoiless replacement).
/// Separate from `BillingInvoice` (Stripe mirror) for now; may unify in Phase 4.
model Invoice {
  id     String        @id @default(uuid())
  status InvoiceStatus @default(draft)
  kind   InvoiceKind   @default(one_off)

  /// Customer-facing number `TL-INV-{n}`, allocated from the shared InvoiceSequence on finalize.
  number String? @unique

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  billToName  String?
  billToLines String[] @default([])

  currency       String   @default("XCD")
  subtotal       Decimal  @default(0) @db.Decimal(12, 2)
  taxLabel       String?
  taxRatePercent Decimal? @db.Decimal(5, 2)
  taxTotal       Decimal  @default(0) @db.Decimal(12, 2)
  total          Decimal  @default(0) @db.Decimal(12, 2)
  /// Sum of recorded payments; `amountDue` = total − amountPaid.
  amountPaid     Decimal  @default(0) @db.Decimal(12, 2)
  amountDue      Decimal  @default(0) @db.Decimal(12, 2)

  issueDate           DateTime  @default(now())
  dueDate             DateTime?
  notes               String?   @db.Text
  /// Cash/bank/cheque payment instructions printed on the PDF (key for non-card payers).
  paymentInstructions String?   @db.Text
  /// When true, the public pay link offers Stripe Checkout for the outstanding balance.
  allowOnlinePayment  Boolean   @default(false)

  publicToken String?   @unique
  sentAt      DateTime?
  paidAt      DateTime?
  voidedAt    DateTime?

  pdfStoragePath String?
  pdfGeneratedAt DateTime?

  /// Quote this invoice was converted from (back-reference; FK lives on Quote.convertedInvoiceId).
  sourceQuote         Quote?  @relation("QuoteConvertedInvoice")
  /// Optional ops link for traceability to a device service assignment.
  serviceAssignmentId String?
  /// Recurring schedule that generated this invoice (when kind = recurring).
  recurringScheduleId String?
  recurringSchedule   RecurringInvoiceSchedule? @relation("ScheduleGeneratedInvoices", fields: [recurringScheduleId], references: [id], onDelete: SetNull)
  /// Stripe `BillingInvoice` mirror row (when kind = subscription_mirror).
  billingInvoiceId String?        @unique
  billingInvoice   BillingInvoice? @relation(fields: [billingInvoiceId], references: [id], onDelete: SetNull)

  /// Source Invoiless invoice id when `kind = invoiless_import` (dedup for backfill).
  invoilessInvoiceId   String?   @unique
  /// Original Invoiless invoice number for display on imported rows.
  legacyInvoiceNumber  String?
  importedAt           DateTime?

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  lineItems InvoiceLineItem[]
  payments  Payment[]
  lastOnSchedule RecurringInvoiceSchedule? @relation("ScheduleLastInvoice")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([dueDate])
  @@index([updatedAt])
  @@index([recurringScheduleId])
}

/// Template for auto-generated recurring TL invoices (replaces Invoiless retainers).
model RecurringInvoiceSchedule {
  id     String                  @id @default(uuid())
  status RecurringScheduleStatus @default(active)
  /// Staff label, e.g. "Fleet monitoring — Acme Ltd".
  name   String?

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  billToName  String?
  billToLines String[] @default([])

  currency       String   @default("XCD")
  taxLabel       String?
  taxRatePercent Decimal? @db.Decimal(5, 2)
  notes               String? @db.Text
  paymentInstructions String? @db.Text

  /// Billing cadence in months (1, 3, 6, or 12).
  intervalMonths    Int @default(1)
  /// Next date to issue an invoice (UTC noon semantics in app code).
  nextIssueDate     DateTime
  /// Due date = issue date + this many calendar days.
  dueDaysAfterIssue Int      @default(30)

  autoEmail Boolean @default(true)
  /// Override recipient; defaults to linked customer email when null.
  emailTo   String?

  serviceAssignmentId String?

  lastGeneratedAt DateTime?
  lastInvoiceId   String?  @unique
  lastInvoice     Invoice? @relation("ScheduleLastInvoice", fields: [lastInvoiceId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  lineItems         RecurringScheduleLineItem[]
  generatedInvoices Invoice[]                 @relation("ScheduleGeneratedInvoices")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([status, nextIssueDate])
}

model RecurringScheduleLineItem {
  id String @id @default(uuid())

  scheduleId String
  schedule   RecurringInvoiceSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  sortOrder   Int     @default(0)
  description String
  quantity    Decimal @default(1) @db.Decimal(12, 4)
  unitLabel   String?
  unitPrice   Decimal @db.Decimal(12, 2)
  lineTotal   Decimal @default(0) @db.Decimal(12, 2)

  @@index([scheduleId])
}

model InvoiceLineItem {
  id String @id @default(uuid())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  sortOrder   Int     @default(0)
  description String
  quantity    Decimal @default(1) @db.Decimal(12, 4)
  unitLabel   String?
  unitPrice   Decimal @db.Decimal(12, 2)
  lineTotal   Decimal @default(0) @db.Decimal(12, 2)

  @@index([invoiceId])
}

/// A payment received against a native invoice (supports partial + manual methods).
model Payment {
  id String @id @default(uuid())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  /// Denormalized for AR/customer reporting; nullable for ad-hoc invoices.
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  amount                Decimal       @db.Decimal(12, 2)
  currency              String        @default("XCD")
  method                PaymentMethod @default(cash)
  /// External or manual reference (cheque #, bank ref, Stripe PaymentIntent id).
  reference             String?
  stripePaymentIntentId String?
  receivedAt            DateTime      @default(now())
  notes                 String?

  recordedById String?
  recordedBy   User?   @relation(fields: [recordedById], references: [id], onDelete: SetNull)

  voidedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([invoiceId])
  @@index([customerId, receivedAt(sort: Desc)])
}

// --- Native billing (Phase 5): expense register ---

model ExpenseCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  expenses Expense[]

  @@index([sortOrder])
}

/// Simple ops expense — vendor, amount, date, optional receipt and cost attribution.
model Expense {
  id          String               @id @default(uuid())
  vendor      String
  description String?
  amount      Decimal              @db.Decimal(12, 2)
  currency    String               @default("XCD")
  expenseDate DateTime
  method      ExpensePaymentMethod @default(card)
  /// Cheque #, bank ref, card last four, etc.
  reference   String?
  notes       String?              @db.Text

  categoryId String?
  category   ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  deviceId String?
  device   Device? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  /// Vercel Blob url or `private:` prefix, or local `/uploads/expenses/…` path.
  receiptStoragePath String?

  recordedById String?
  recordedBy   User?   @relation(fields: [recordedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expenseDate(sort: Desc)])
  @@index([categoryId])
  @@index([customerId])
  @@index([deviceId])
}
