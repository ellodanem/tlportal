// TL Portal — Track Lucia admin
// https://www.prisma.io/docs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---

enum DeviceStatus {
  in_stock
  assigned
  suspended
  returned
  decommissioned
  lost
}

enum DeviceCondition {
  new
  refurbished
  faulty
}

enum ServiceAssignmentStatus {
  active
  due_soon
  overdue
  suspended
  cancelled
}

enum RegistrationRequestStatus {
  pending
  approved
  rejected
}

/// Commercial / lifecycle classification (default: customer-facing production units).
enum DeviceUsagePurpose {
  customer
  internal_demo
  field_test
  personal
}

/// What the tracker is installed on (fleet / ops labeling).
enum DeviceObjectType {
  car
  bike
  ambulance
  fire_truck
  atv
  boat
  container
  bus
  garbage_truck
  jet_ski
  speed_boat
}

enum ProposalStatus {
  draft
  sent
}

enum ProposalLineCategory {
  hardware
  subscription
  installation
  service
  other
}

enum ProposalVisualKind {
  media
  timeline
}

enum ProposalVisualLayout {
  full_width
  half_width
}

/// Sidebar logo height preset (admin branding).
enum BrandingLogoSize {
  s
  m
  l
  xl
}

/// How the customer is billed (TL ops view; provider details on BillingAccount).
enum CustomerBillingMode {
  manual_legacy
  stripe_subscription
}

enum BillingProvider {
  invoiless
  stripe
}

enum BillingInvoiceKind {
  subscription
  one_time
}

/// TL-owned subscription lifecycle (Stripe mirrors payment; this is ops source of truth).
enum CustomerSubscriptionStatus {
  pending_payment
  active
  past_due
  unpaid
  canceled
  trialing
  paused
}

/// Broadcast message templates (email now; WhatsApp body reserved for phase 2).
enum BroadcastTemplateCategory {
  outage
  maintenance
  general
  billing
}

enum BroadcastCampaignStatus {
  queued
  sending
  completed
  completed_with_errors
  failed
  cancelled
}

enum BroadcastDeliveryStatus {
  pending
  sent
  failed
  skipped
}

/// GPS / telematics platform linked to a device.
enum GpsProvider {
  traqcare
}

enum DeviceLinkRole {
  primary
  secondary
  migrating
}

/// Atomic counter for customer-facing `TL-INV-{n}` numbers (singleton id = "default").
model InvoiceSequence {
  id        String   @id
  nextValue Int
  updatedAt DateTime @updatedAt
}

// --- App config (singleton row id = "default") ---

model AppSettings {
  id      String   @id
  logoUrl String?
  logoSize BrandingLogoSize @default(m)
  /// Outgoing mail (SMTP). When `smtpHost` is null, other SMTP fields are ignored.
  smtpHost      String?
  smtpPort      Int @default(587)
  /// When true, Nodemailer uses implicit TLS (typical for port 465).
  smtpSecure    Boolean @default(false)
  smtpUser      String?
  smtpPassword  String?
  smtpFromEmail String?
  smtpFromName  String?
  /// Comma- or newline-separated E.164-ish phones for billing ops SMS (missing pay link, etc.).
  billingAlertPhones String? @db.Text
  /// When true, email TL paid receipt PDFs on Stripe `invoice.paid` (requires SMTP).
  autoEmailPaidStripeReceipts Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Auth (admin) ---

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  reviewedRegistrationRequests RegistrationRequest[] @relation("RegistrationReviewedBy")
  proposalsCreated           Proposal[]
}

// --- Core domain ---

model Customer {
  id                  String    @id @default(uuid())
  firstName           String?
  lastName            String?
  company             String?
  email               String?
  phone               String?
  /// Street / multi-line address (Invoiless “Address”); city/state/postal/country are composed into billTo.address on sync.
  address             String?
  city                String?
  state               String?
  postalCode          String?
  country             String?
  /// Maps to Invoiless billTo.legal (e.g. company / tax registration).
  legalInfo           String?
  /// Comma-separated Cc emails for invoice sends (Invoiless max 3).
  invoiceCc           String?
  /// Comma-separated Bcc emails (Invoiless max 3).
  invoiceBcc          String?
  /// Preferred billing path for new workflows (legacy rows default manual_legacy).
  billingMode CustomerBillingMode @default(manual_legacy)
  /// Custom Stripe subscription monthly rate (XCD). Null = default catalog / env Price ids.
  stripeMonthlyRateXcd Decimal? @db.Decimal(10, 2)
  /// @deprecated Prefer BillingAccount — kept for backward compatibility during Phase 1.
  invoilessCustomerId String?   @unique
  /// @deprecated Prefer ProviderDeviceLink on Device — kept during Phase 1 migration.
  traqcareUsername    String?
  /// Stored in DB as plain text — restrict DB access; prefer env/secret store for production.
  traqcarePassword    String?
  /// Traqcare / white-label portal base URL if not the default (e.g. https://…).
  traqcarePortalUrl   String?
  /// Traqcare live API `clientid` — one fleet id per customer (copy from Traqcare platform).
  traqcareClientId    String?
  notes               String?
  tags                String[]  @default([])
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  serviceAssignments ServiceAssignment[]
  billingAccounts       BillingAccount[]
  billingInvoices          BillingInvoice[]
  billingWhatsAppReminders  BillingWhatsAppReminder[]
  billingPayLinkAdminAlerts  BillingPayLinkAdminAlert[]
  customerWhatsAppDeliveries CustomerWhatsAppDelivery[]
  customerSubscriptions      CustomerSubscription[]
  operationalEvents        OperationalEvent[]
  broadcastDeliveries   BroadcastDelivery[]

  registrationEmailMatches RegistrationRequest[] @relation("RegistrationEmailMatchCustomer")
  createdFromRegistration    RegistrationRequest?  @relation("RegistrationCreatedCustomer")
  proposals                  Proposal[]

  @@index([email])
}

/// Public registration form — four fixed terms (1 / 3 / 6 / 12 month); staff edit price only.
model SubscriptionOption {
  id             String   @id @default(uuid())
  /// Billing term length in months; exactly one row per value in { 1, 3, 6, 12 }.
  durationMonths Int      @unique
  priceXcd       Decimal  @db.Decimal(10, 2)
  /// Stripe Price id (`price_…`) for Checkout; overrides env `STRIPE_PRICE_ID_*` when set.
  stripePriceId  String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  registrationRequests RegistrationRequest[]
}

/// Stripe catalog: per-vehicle Price id for monthly rate tier × billing term (Checkout quantity = vehicles).
model SubscriptionCatalogPrice {
  id             String   @id @default(uuid())
  /// Per-vehicle monthly rate tier (e.g. 30, 25, 20 XCD).
  monthlyRateXcd Decimal  @db.Decimal(10, 2)
  durationMonths Int
  /// Stripe Price (`price_…`) per vehicle for this billing interval.
  stripePriceId  String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([monthlyRateXcd, durationMonths])
  @@index([durationMonths])
}

/// Client-submitted registration; staff approves → Customer created (Invoiless separate).
model RegistrationRequest {
  id     String                    @id @default(uuid())
  status RegistrationRequestStatus @default(pending)

  firstName String
  lastName  String
  /// WhatsApp / primary phone from the registration form.
  phone String
  email String

  vehicleDetails       String  @db.Text
  /// Optional extra portal users from the registration form (free text, one per line).
  additionalUsers String? @db.Text
  subscriptionOptionId String?
  subscriptionOption   SubscriptionOption? @relation(fields: [subscriptionOptionId], references: [id], onDelete: SetNull)

  termInstallAfterPayment Boolean
  termHardwarePerVehicle  Boolean
  termTravelFee           Boolean

  /// Existing customer with the same email (reviewer duplicate flag).
  matchesCustomerId String?
  matchesCustomer   Customer? @relation("RegistrationEmailMatchCustomer", fields: [matchesCustomerId], references: [id], onDelete: SetNull)
  /// Count of other pending rows with the same email when this row was submitted.
  otherPendingSameEmail Int @default(0)

  submittedAt DateTime  @default(now())
  reviewedAt  DateTime?
  reviewedById String?
  reviewedBy   User?   @relation("RegistrationReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  rejectionReason String? @db.Text

  createdCustomerId String?  @unique
  createdCustomer   Customer? @relation("RegistrationCreatedCustomer", fields: [createdCustomerId], references: [id], onDelete: SetNull)

  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([submittedAt])
}

model DeviceModel {
  id                 String   @id @default(uuid())
  name               String
  manufacturer       String?
  category           String?
  description        String?
  retailPrice        Decimal  @db.Decimal(12, 2)
  costPrice          Decimal? @db.Decimal(12, 2)
  invoilessProductId String?  @unique
  isActive           Boolean  @default(true)
  imageUrl           String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  devices Device[]
}

model Device {
  id                String          @id @default(uuid())
  imei              String          @unique
  serialNumber      String?
  label             String?
  status            DeviceStatus    @default(in_stock)
  condition         DeviceCondition @default(new)
  purchasedAt       DateTime?
  warrantyExpiresAt DateTime?
  firmwareVersion   String?
  notes             String?
  /// Billable / customer-facing vs internal, demo, or personal test units.
  usagePurpose DeviceUsagePurpose @default(customer)
  /// Vehicle / asset class for UI and reporting (optional).
  objectType   DeviceObjectType?
  /// Free-form labels (e.g. demo-booth, test-vehicle-a); use for search and reporting.
  tags         String[]           @default([])
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  deviceModelId String
  deviceModel   DeviceModel @relation(fields: [deviceModelId], references: [id], onDelete: Restrict)

  simCardId String?  @unique
  simCard   SimCard? @relation(fields: [simCardId], references: [id], onDelete: SetNull)

  serviceAssignments   ServiceAssignment[]
  providerDeviceLinks  ProviderDeviceLink[]
  operationalEvents    OperationalEvent[]

  @@index([deviceModelId])
  @@index([status])
  @@index([usagePurpose])
  @@index([objectType])
}

model SimCard {
  id             String    @id @default(uuid())
  iccid          String    @unique
  msisdn         String?
  imsi           String?
  label          String?
  status         String    @default("Active")
  totalDataMB    Float?
  usedDataMB     Float?
  dataExpiryDate DateTime?
  lastSyncedAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  device Device?

  serviceAssignments ServiceAssignment[]

  @@index([iccid])
  @@index([status])
  @@index([usedDataMB])
}

model ServiceAssignment {
  id                   String                   @id @default(uuid())
  startDate            DateTime?
  endDate              DateTime?
  status               ServiceAssignmentStatus  @default(active)
  invoilessRecurringId String?
  intervalMonths       Int?
  lastInvoiceId        String?
  lastPaymentStatus    String?
  nextDueDate          DateTime?
  notes                String?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  deviceId String
  device   Device @relation(fields: [deviceId], references: [id], onDelete: Restrict)

  simCardId String?
  simCard   SimCard? @relation(fields: [simCardId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([deviceId])
  @@index([status])
  @@index([nextDueDate])
}

/// Sales proposal (PDF to client). Estimate/invoice flow is separate (e.g. Invoiless).
model Proposal {
  id     String         @id @default(uuid())
  status ProposalStatus @default(draft)

  title String

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  /// Primary display name on cover (company or contact).
  clientLabel       String?
  clientCompany     String?
  clientContactName String?
  clientEmail       String?
  clientPhone       String?
  clientAddress     String? @db.Text

  executiveSummary String? @db.Text
  /// Plain text: one bullet per line for the “included capabilities” section.
  includedFeatures String? @db.Text
  assumptionsText  String? @db.Text
  nextStepsText    String? @db.Text
  termsText        String? @db.Text
  pricingFootnote  String? @db.Text

  currencyCode String @default("XCD")
  validityDays Int    @default(14)

  salesContactName  String?
  salesContactTitle String?
  salesContactEmail String?
  salesContactPhone String?

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  lineItems ProposalLineItem[]
  visuals   ProposalVisualBlock[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([updatedAt])
}

model ProposalLineItem {
  id String @id @default(uuid())

  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  sortOrder Int                  @default(0)
  category  ProposalLineCategory @default(other)

  description String
  quantity    Decimal @default(1) @db.Decimal(12, 4)
  unitLabel   String?
  unitPrice   Decimal @db.Decimal(12, 2)

  @@index([proposalId])
}

model ProposalVisualBlock {
  id String @id @default(uuid())

  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  sortOrder Int     @default(0)
  title           String
  caption         String? @db.Text
  imageUrl        String?
  placeholderHint String?
  /// Accessibility / PDF note when an image is present.
  imageAlt        String?
  kind            ProposalVisualKind   @default(media)
  layout          ProposalVisualLayout @default(full_width)
  /// When `kind` is `timeline`, JSON array of { "title": string, "detail"?: string }.
  timelineSteps   Json?

  @@index([proposalId])
}

// --- Vendor abstraction (Phase 1) ---

/// External billing identity per customer (Invoiless, Stripe, …).
model BillingAccount {
  id                 String              @id @default(uuid())
  customerId         String
  customer           Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  provider           BillingProvider
  externalCustomerId String
  mode               CustomerBillingMode @default(manual_legacy)
  /// Provider-specific status mirror (e.g. Stripe subscription status).
  status             String?
  metadata           Json?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([customerId, provider])
  @@unique([provider, externalCustomerId])
  @@index([customerId])
}

/// Mirrored invoice from a billing provider (Stripe subscription/one-time, future Invoiless).
model BillingInvoice {
  id                     String             @id @default(uuid())
  customerId             String
  customer               Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  provider               BillingProvider
  externalInvoiceId      String
  kind                   BillingInvoiceKind @default(subscription)
  status                 String
  amountXcd              Decimal            @db.Decimal(12, 2)
  currency               String             @default("xcd")
  /// Customer-facing number on PDF and Billing UI (e.g. TL-INV-100837).
  displayNumber          String?            @unique
  /// Provider invoice number (Stripe `invoice.number`).
  providerInvoiceNumber  String?
  periodStart            DateTime?
  periodEnd              DateTime?
  hostedInvoiceUrl       String?
  invoicePdfUrl          String?
  stripeSubscriptionId   String?
  paidAt                 DateTime?
  /// Invoiless invoice id created when mirroring Stripe `invoice.paid` (accounting copy).
  invoilessMirrorInvoiceId String?
  /// Vercel Blob path prefix `private:` + url, or public blob url for TL paid PDF.
  pdfStoragePath         String?
  pdfGeneratedAt         DateTime?
  /// When the TL paid receipt PDF was emailed to the customer (auto or manual).
  receiptEmailedAt       DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  @@unique([provider, externalInvoiceId])
  @@index([customerId, createdAt(sort: Desc)])
  @@index([status])
}

/// Sent billing WhatsApp reminders (Twilio Content); one row per customer × kind × due date.
model BillingWhatsAppReminder {
  id               String   @id @default(uuid())
  customerId       String
  customer         Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  /// due_5d | due_3d | due_0d | overdue_3d | overdue_5d
  reminderKind     String
  nextDueDate      DateTime @db.Date
  twilioMessageSid String?
  payLinkSource    String?
  sentAt           DateTime @default(now())

  @@unique([customerId, reminderKind, nextDueDate])
  @@index([customerId, sentAt(sort: Desc)])
}

/// One-off customer WhatsApp (Stripe checkout link, new Invoiless invoice).
model CustomerWhatsAppDelivery {
  id               String   @id @default(uuid())
  customerId       String
  customer         Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  kind             String
  externalRef      String
  twilioMessageSid String?
  sentAt           DateTime @default(now())

  @@unique([kind, externalRef])
  @@index([customerId, sentAt(sort: Desc)])
}

/// Staff SMS sent when a customer reminder was skipped (no pay link).
model BillingPayLinkAdminAlert {
  id           String   @id @default(uuid())
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  reminderKind String
  nextDueDate  DateTime @db.Date
  notifiedAt   DateTime @default(now())

  @@unique([customerId, reminderKind, nextDueDate])
  @@index([notifiedAt(sort: Desc)])
}

/// Idempotency for Stripe webhooks (`evt_…` primary key).
model StripeWebhookEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now())

  @@index([processedAt])
}

/// Customer-level subscription (TL source of truth; Stripe id when linked).
model CustomerSubscription {
  id                   String                     @id @default(uuid())
  customerId           String
  customer             Customer                   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  status               CustomerSubscriptionStatus @default(pending_payment)
  /// Billing term length in months (1, 3, 6, 12).
  planTermMonths       Int
  /// Monthly rate in XCD used for this subscription (null = catalog default at checkout).
  monthlyRateXcd       Decimal?                   @db.Decimal(10, 2)
  /// Billed vehicle/device quantity when set; otherwise derived from active assignments in UI.
  vehicleCount         Int?
  stripeSubscriptionId String?                    @unique
  stripeCustomerId     String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAt             DateTime?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  @@index([customerId, updatedAt(sort: Desc)])
  @@index([status])
}

/// Maps a TL device to a vendor GPS/telematics identity.
model ProviderDeviceLink {
  id                 String         @id @default(uuid())
  deviceId           String
  device             Device         @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  provider           GpsProvider
  externalDeviceId   String?
  externalAccountRef String?
  portalUrl          String?
  role               DeviceLinkRole @default(primary)
  linkedAt           DateTime       @default(now())
  unlinkedAt         DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@unique([deviceId, provider])
  @@index([deviceId])
  @@index([provider])
}

/// Reusable copy for customer broadcast emails (and future WhatsApp).
model BroadcastTemplate {
  id           String                   @id @default(uuid())
  /// Stable key for seeded system templates (`outage-investigating`, etc.).
  slug         String?                  @unique
  name         String
  category     BroadcastTemplateCategory @default(general)
  subject      String
  bodyText     String                   @db.Text
  /// Phase 2: shorter plain body for WhatsApp when channel is enabled.
  whatsappBody String?                  @db.Text
  isSystem     Boolean                  @default(false)
  isActive     Boolean                  @default(true)
  sortOrder    Int                      @default(0)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  campaigns    BroadcastCampaign[]

  @@index([category])
  @@index([isActive, sortOrder])
}

/// Mass email send to a filtered customer audience (snapshot subject/body at send time).
model BroadcastCampaign {
  id                String                  @id @default(uuid())
  templateId        String?
  template          BroadcastTemplate?      @relation(fields: [templateId], references: [id], onDelete: SetNull)
  subjectSnapshot   String
  bodyTextSnapshot  String                  @db.Text
  /// When false, only customers with an active service assignment; when true, all customers with email.
  includeInactive   Boolean                 @default(false)
  incidentTitle     String?
  incidentStatus    String?
  incidentEta       String?
  status            BroadcastCampaignStatus @default(queued)
  totalRecipients   Int                     @default(0)
  sentCount         Int                     @default(0)
  failedCount       Int                     @default(0)
  skippedCount      Int                     @default(0)
  actorUserId       String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  startedAt         DateTime?
  completedAt       DateTime?

  deliveries BroadcastDelivery[]

  @@index([status, createdAt])
  @@index([createdAt])
}

/// Per-customer email attempt for a broadcast campaign.
model BroadcastDelivery {
  id         String                  @id @default(uuid())
  campaignId String
  campaign   BroadcastCampaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer                @relation(fields: [customerId], references: [id], onDelete: Cascade)
  email      String
  status     BroadcastDeliveryStatus @default(pending)
  error      String?
  sentAt     DateTime?
  createdAt  DateTime                @default(now())

  @@unique([campaignId, customerId])
  @@index([campaignId, status])
  @@index([customerId])
}

/// TL-native audit trail for ops and future automation (not vendor telemetry).
model OperationalEvent {
  id          String    @id @default(uuid())
  occurredAt  DateTime  @default(now())
  category    String
  summary     String
  payload     Json?
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  deviceId    String?
  device      Device?   @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  actorUserId String?

  @@index([customerId, occurredAt])
  @@index([deviceId, occurredAt])
  @@index([category, occurredAt])
}
