# Postgres (local Docker: see docker-compose.yml)
DATABASE_URL="postgresql://tlportal:tlportal@localhost:5432/tlportal?schema=public"
# Same as DATABASE_URL for Docker. On Neon + Vercel: use the direct (non-pooler) URL here — see README Deploy.
DIRECT_URL="postgresql://tlportal:tlportal@localhost:5432/tlportal?schema=public"

INVOILESS_API_KEY=
INVOILESS_WEBHOOK_SECRET=
# Optional; defaults to XCD in customer sync
# INVOILESS_DEFAULT_CURRENCY=XCD

ONCE_CLIENT_ID=
ONCE_CLIENT_SECRET=

# Nightly SIM sync (GET /api/cron/nightly-sims-sync). Vercel Cron sends Authorization: Bearer <CRON_SECRET>.
# Generate a long random string; must match the value configured for the cron job / external scheduler.
CRON_SECRET=

# JWT signing (min 32 characters). Required for /api/auth/* and /admin
AUTH_SECRET=

# Optional: prisma db seed — creates admin User
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Vercel Blob: required on Vercel for Settings → branding logo upload (local dev uses public/uploads/ instead).
# Works with both public and private Blob stores (private logos stream from /api/branding/logo for signed-in admins).
BLOB_READ_WRITE_TOKEN=

# Optional: overrides SMTP password from Settings (recommended on Vercel instead of storing in DB)
# SMTP_PASSWORD=

# Proposal PDF letterhead (defaults: legal name Ellodane Enterprises, brand line Track Lucia)
# PROPOSAL_LEGAL_NAME=Ellodane Enterprises
# PROPOSAL_ISSUER_NAME=   # legacy alias for PROPOSAL_LEGAL_NAME
# PROPOSAL_BRAND_TAGLINE=Track Lucia   # set empty or "-" to hide brand line under legal name
# PROPOSAL_ISSUER_ADDRESS=TrackLucia.com\nCity, Country
