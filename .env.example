# Postgres (local Docker: see docker-compose.yml)
DATABASE_URL="postgresql://tlportal:tlportal@localhost:5432/tlportal?schema=public"
# Same as DATABASE_URL for Docker. On Neon + Vercel: use the direct (non-pooler) URL here — see README Deploy.
DIRECT_URL="postgresql://tlportal:tlportal@localhost:5432/tlportal?schema=public"

INVOILESS_API_KEY=
# Webhook signing secret from Invoiless → Configure webhooks (HMAC header `invoiless-signature`). Optional alias: INVOILESS_SECRET
INVOILESS_WEBHOOK_SECRET=
# Optional. If set, GET /api/webhooks/invoiless requires x-tl-webhook-debug or Authorization: Bearer (inspect last POST).
INVOILESS_WEBHOOK_DEBUG_TOKEN=
# Optional; defaults to XCD in customer sync
# INVOILESS_DEFAULT_CURRENCY=XCD
# Mirror Stripe invoice.paid into Invoiless as Paid (accounting). Set 0/false to disable.
# INVOILESS_STRIPE_MIRROR=true
# Native billing (Phase 7): default on — TL invoices are primary; Invoiless mirror + legacy UI off unless opted in.
# NATIVE_BILLING_PRIMARY=true
# INVOILESS_LEGACY_UI=true
# Advance ServiceAssignment nextDueDate on Stripe invoice.paid (all active devices). Set 0/false to disable.
# STRIPE_RENEWAL_AUTO_ADVANCE=true

# Stripe recurring subscriptions (Checkout + webhooks + Customer Portal)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Webhook endpoint must include checkout.session.expired for automatic recovery emails (SMTP required)
# Set to 0 or false to disable Stripe UI/actions while keeping keys in env
# STRIPE_BILLING_ENABLED=true
# Legacy $30/mo catalog (optional fallback): STRIPE_PRICE_ID_1MO, _3MO, _6MO, _12MO
# Per-vehicle catalog (preferred): STRIPE_PRICE_{rate}_{term}MO e.g. STRIPE_PRICE_30_1MO=price_…
# STRIPE_PRICE_30_1MO=
# STRIPE_PRICE_30_3MO=
# STRIPE_PRICE_25_6MO=
# Or set Price ids in Admin → Subscription options → Stripe catalog table
STRIPE_PRICE_ID_1MO=
STRIPE_PRICE_ID_3MO=
STRIPE_PRICE_ID_6MO=
STRIPE_PRICE_ID_12MO=
# Optional; defaults to xcd (must match your Stripe account currency)
# STRIPE_CHECKOUT_CURRENCY=xcd
# Automatic BCC copy for Stripe Checkout customer emails (initial send + expired-link recovery)
# STRIPE_CHECKOUT_EMAIL_BCC=ellodaneenterprises@gmail.com
# TL paid invoice PDFs (Vercel Blob). First TL-INV number defaults to 100900 unless set:
# INVOICE_SEQUENCE_START=100900
# Native billing (Phase 0): first TL-Q quote number; defaults to 1000 unless set:
# QUOTE_SEQUENCE_START=1000
# BLOB_READ_WRITE_TOKEN=   # required for TL receipt PDF storage (Vercel Blob)
# Checkout/Portal return URLs (production: https://your-domain)
# APP_BASE_URL=https://localhost:3000
# NEXT_PUBLIC_APP_URL=https://localhost:3000

ONCE_CLIENT_ID=
ONCE_CLIENT_SECRET=

# Traqcare live tracking API (server-only; not wired yet). See docs/traqcare-live-tracking-api.md
# TRAQCARE_LIVE_API_BASE_URL=https://a1.traqcare.com/v2.12/tracking
# TRAQCARE_LIVE_API_KEY=

# Nightly SIM sync (GET /api/cron/nightly-sims-sync). Vercel Cron sends Authorization: Bearer <CRON_SECRET>.
# Generate a long random string; must match the value configured for the cron job / external scheduler.
CRON_SECRET=
# Broadcast cron batch size (GET /api/cron/broadcast-send). Default 50 on Hobby (daily cron).
# BROADCAST_CRON_BATCH_SIZE=50

# Twilio WhatsApp billing reminders (GET /api/cron/billing-whatsapp-reminders, daily 04:15 UTC)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+1XXXXXXXXXX
# TWILIO_WA_TEMPLATE_DUE_5_DAYS=HX...
# TWILIO_WA_TEMPLATE_DUE_3_DAYS=HX...
# TWILIO_WA_TEMPLATE_DUE_TODAY=HX...
# TWILIO_WA_TEMPLATE_OVERDUE_3_DAYS=HX...   # or use TWILIO_WA_TEMPLATE_OVERDUE for both overdue steps
# TWILIO_WA_TEMPLATE_OVERDUE_5_DAYS=HX...
# TWILIO_WA_TEMPLATE_OVERDUE=HX...
# TWILIO_WA_TEMPLATE_STRIPE_PAYMENT_LINK=HXa01e85c427ca68a423295271a6a8839d   # tl_stripe_payment_link_2
# TWILIO_WA_TEMPLATE_STRIPE_PAYMENT_LINK_RESEND=HX0d1829b2712904c57a937f5718de64e5  # tl_stripe_payment_link_resend_2
# TWILIO_WA_TEMPLATE_INVOICE_NEW=HX...
# TWILIO_WA_TEMPLATE_PAYMENT_DECLINED=HX...   # Utility template; URL button base https://<domain>/pay/go/{{5}}
# TWILIO_WA_TEMPLATE_OUTSTANDING_INVOICES=HX...   # Multi-invoice reminder; {{1}} name, {{2}} invoice lines with pay links
# Inbound WhatsApp webhook: POST https://<host>/api/webhooks/twilio/whatsapp
# Optional exact public URL for signature validation (defaults to APP_BASE_URL + path):
# TWILIO_WHATSAPP_WEBHOOK_URL=https://tlportal.vercel.app/api/webhooks/twilio/whatsapp
# BILLING_REMINDER_TIMEZONE=America/St_Lucia
# TWILIO_WA_ALLOW_SEND_WITHOUT_PAY_LINK=false
# SMS sender for staff billing alerts (defaults to TWILIO_WHATSAPP_FROM number without whatsapp: prefix)
# TWILIO_SMS_FROM=+1XXXXXXXXXX

# JWT signing (min 32 characters). Required for /api/auth/* and /admin
AUTH_SECRET=

# Optional: prisma db seed — creates/updates super admin
SUPER_ADMIN_EMAIL=dane.elrus1@gmail.com
SUPER_ADMIN_PASSWORD=
# Backward compatible aliases
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Vercel Blob: required on Vercel for Settings → branding logo upload (local dev uses public/uploads/ instead).
# Works with both public and private Blob stores (private logos stream from /api/branding/logo for signed-in admins).
BLOB_READ_WRITE_TOKEN=

# Optional: overrides SMTP password from Settings (recommended on Vercel instead of storing in DB)
# SMTP_PASSWORD=

# Proposal PDF letterhead (defaults: legal name Ellodane Enterprises, brand line Track Lucia)
# PROPOSAL_LEGAL_NAME=Ellodane Enterprises
# PROPOSAL_ISSUER_NAME=   # legacy alias for PROPOSAL_LEGAL_NAME
# PROPOSAL_BRAND_TAGLINE=Track Lucia   # set empty or "-" to hide brand line under legal name
# PROPOSAL_ISSUER_ADDRESS=TrackLucia.com\nCity, Country

# Proposal cover page (PDF + Word): header = Ellodane logo (optional path/blob like branding). If unset, admin branding logo is used.
# PROPOSAL_PDF_HEADER_LOGO=/uploads/branding/ellodane-logo.png
# Center mark under the title (Track Lucia). Defaults to /proposals/track-lucia-cover.png under public/.
# PROPOSAL_PDF_CENTER_LOGO=/proposals/track-lucia-cover.png
